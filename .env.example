# CarStorms configuration — copy to .env and fill in the secrets.
# All variables are prefixed CARSTORMS_ and are optional unless noted.

# --- Directus (required to persist the hazard archive) ---------------------
CARSTORMS_DIRECTUS_URL=https://directus.lanxys.net
# Static access token with permission to read/write items and (for auto-bootstrap)
# create collections/fields. Required.
CARSTORMS_DIRECTUS_TOKEN=
# Optional: change the collection prefix (default carstorm_).
# CARSTORMS_DIRECTUS_COLLECTION_PREFIX=carstorm_

# --- Telegram (required to broadcast warnings) -----------------------------
# Bot token from @BotFather. The bot must be an admin of the channel.
CARSTORMS_TELEGRAM_BOT_TOKEN=
# Public channel, e.g. @carstorms_stjohn  (or a numeric -100... id)
CARSTORMS_TELEGRAM_CHANNEL_ID=

# --- Monitored location (St. John + St. Thomas; NWS zone VIZ001 covers both) -
# CARSTORMS_LOCATION_NAME=St. John, USVI
# CARSTORMS_LATITUDE=18.335
# CARSTORMS_LONGITUDE=-64.735
# CARSTORMS_NWS_OFFICE=SJU
# CARSTORMS_NWS_GRID_X=277
# CARSTORMS_NWS_GRID_Y=120
# CARSTORMS_NWS_ZONES=["VIZ001"]
# CARSTORMS_ST_THOMAS_LATITUDE=18.343
# CARSTORMS_ST_THOMAS_LONGITUDE=-64.931

# --- Extension sources (public safety, utilities, beaches, travel) ----------
# Beach water quality (EPA Water Quality Portal) needs no key.
# CARSTORMS_BEACH_THRESHOLD_CFU=70
# CARSTORMS_BEACH_LOOKBACK_DAYS=180
# CARSTORMS_BEACH_ADVISORY_MAX_AGE_DAYS=10
# Air quality / Saharan dust (EPA AirNow) — set a free key to enable the source:
# CARSTORMS_AIRNOW_API_KEY=
# STT airport: METAR works with no key; FAA NOTAM closures need credentials:
# CARSTORMS_AIRPORT_ICAO=TIST
# CARSTORMS_FAA_CLIENT_ID=
# CARSTORMS_FAA_CLIENT_SECRET=
# WAPA power outages (outage-viewer JSON, no key):
# CARSTORMS_WAPA_OUTAGE_BASE=http://www.outageviewer.viwapa.vi:7575
# CARSTORMS_WAPA_ALERT_MIN_CUSTOMERS=25

# --- Detection thresholds --------------------------------------------------
# CARSTORMS_TROPICAL_ALERT_RADIUS_KM=400
# CARSTORMS_EARTHQUAKE_RADIUS_KM=500
# CARSTORMS_EARTHQUAKE_MIN_MAGNITUDE=2.5

# --- Messaging cadence -----------------------------------------------------
# CARSTORMS_MIN_MESSAGE_INTERVAL_MINUTES=30
# CARSTORMS_HEARTBEAT_WARNING_MINUTES=90
# CARSTORMS_HEARTBEAT_WATCH_MINUTES=360
# CARSTORMS_POLL_INTERVAL_CALM_SECONDS=900
# CARSTORMS_POLL_INTERVAL_ACTIVE_SECONDS=180

# --- Dashboard (served by the worker at / on the health port) --------------
# CARSTORMS_DASHBOARD_ENABLED=true
# CARSTORMS_DASHBOARD_REFRESH_SECONDS=300
# CARSTORMS_TIDE_STATION_ID=9751381      # NOAA CO-OPS Lameshur Bay, St. John
# CARSTORMS_NDBC_BUOY_ID=41052           # buoy south of St. John (observed when fresh)

# --- Runtime ---------------------------------------------------------------
# CARSTORMS_LOG_LEVEL=INFO
# CARSTORMS_LOG_JSON=true
# CARSTORMS_HEALTH_PORT=8080
